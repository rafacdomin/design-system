{
  "name": "design-system-root",
  "private": true,
  "packageManager": "pnpm@11.2.2",
  "type": "module",
  "version": "1.0.0",
  "description": "Mini Design System Monorepo",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
